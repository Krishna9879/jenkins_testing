pipeline{
    agent any 

    environment{
        VERSION = "7.8.9"
    }
    stages{
        stage("compile"){
            steps{
               sh 'javac Main.java'
            }
        }

        stage("run"){
            steps{
                sh 'java Main.java'
                sh "echo '${VERSION}'"
            }
        }
    }

    post{
        always {
            sh 'echo "always"'
        }
        success {
            sh 'echo "success"'
        }
        failure {
            sh 'echo "failure"'
        }
    }
}